{
  "name": "meet-a-rwandan-local",
  "version": "1.0.0",
  "description": "A mobile application connecting tourists with local Rwandans for authentic cultural experiences",
  "private": true,
  "workspaces": [
    "backend",
    "MeetARwandanLocal"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:mobile\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:mobile": "cd MeetARwandanLocal && npm start",
    "build": "npm run build:backend && npm run build:mobile",
    "build:backend": "cd backend && npm run build",
    "build:mobile": "cd MeetARwandanLocal && expo build",
    "install:all": "npm install && cd backend && npm install && cd ../MeetARwandanLocal && npm install",
    "clean": "rm -rf node_modules backend/node_modules MeetARwandanLocal/node_modules",
    "test": "npm run test:backend",
    "test:backend": "cd backend && npm test",
    "lint": "npm run lint:backend",
    "lint:backend": "cd backend && npm run lint",
    "start:prod": "cd backend && npm start"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "rwanda",
    "tourism",
    "cultural-exchange",
    "mobile-app",
    "react-native",
    "nodejs",
    "community-based-tourism"
  ],
  "author": "Meet a Rwandan Local Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/meetarwandanlocal/mobile-app.git"
  },
  "bugs": {
    "url": "https://github.com/meetarwandanlocal/mobile-app/issues"
  },
  "homepage": "https://meetarwandanlocal.com"
}